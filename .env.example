# UrbanFlow CDMX — Variables de entorno
# Copiar a .env y completar con valores reales (nunca commitear .env)

# Base de datos
DATABASE_URL=postgresql://user:password@localhost:5432/urbanflow

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# APIs externas
TOMTOM_API_KEY=
OPENWEATHERMAP_API_KEY=
METROBUS_GTFS_RT_URL=
GOOGLE_MAPS_API_KEY=

# Configuración de la app
APP_ENV=development
LOG_LEVEL=INFO
