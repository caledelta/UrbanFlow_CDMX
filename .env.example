# UrbanFlow CDMX — Variables de entorno
# Copiar a .env y completar con valores reales (nunca commitear .env)

# Base de datos
DATABASE_URL=postgresql://user:password@localhost:5432/urbanflow

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# APIs externas
TOMTOM_API_KEY=
OPENWEATHERMAP_API_KEY=
METROBUS_GTFS_RT_URL=
GOOGLE_MAPS_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VIALAI_STT_BACKEND=local      # "local" (faster-whisper, gratis) | "openai" (Whisper API)
VIALAI_TTS_BACKEND=openai     # "openai" (tts-1) | "local" (pyttsx3 SAPI5) | "off"

# Configuración de la app
APP_ENV=development
LOG_LEVEL=INFO
